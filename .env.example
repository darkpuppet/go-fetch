# Firebase web app configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Web Push certificate key pair (Firebase Console -> Project settings -> Cloud Messaging)
# Required for push notifications.
VITE_FIREBASE_VAPID_KEY=

# Google Maps JavaScript API key (enable Maps, Places, and Geocoding APIs)
VITE_GOOGLE_MAPS_API_KEY=

# Optional default map center, used before truck data loads
VITE_DEFAULT_MAP_LAT=39.9526
VITE_DEFAULT_MAP_LNG=-75.1652
