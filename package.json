{
  "name": "go-fetch",
  "version": "0.1.0",
  "private": true,
  "description": "A Quasar and Firebase PWA for finding nearby food trucks.",
  "type": "module",
  "scripts": {
    "dev": "quasar dev",
    "dev:pwa": "quasar dev -m pwa",
    "build": "quasar build -m pwa",
    "build:spa": "quasar build",
    "typecheck": "vue-tsc --noEmit",
    "postinstall": "quasar prepare"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darkpuppet/go-fetch.git"
  },
  "keywords": [
    "food-trucks",
    "pwa",
    "quasar",
    "firebase",
    "google-maps"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/darkpuppet/go-fetch/issues"
  },
  "homepage": "https://github.com/darkpuppet/go-fetch#readme",
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@quasar/extras": "^2.0.1",
    "firebase": "^12.14.0",
    "libphonenumber-js": "^1.13.6",
    "pinia": "^3.0.4",
    "quasar": "^2.20.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.6.2",
    "@quasar/cli": "^5.0.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.9.3",
    "autoprefixer": "^10.5.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.4",
    "workbox-build": "^7.4.1"
  },
  "engines": {
    "node": ">=18"
  }
}
