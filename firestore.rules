rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles (users/{uid}): a signed-in user may read and write only
    // their own document. The stored `uid` must match the authenticated user.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId;

      allow delete: if false;
    }

    // Food trucks (foodTrucks/{id}): readable by everyone so the map works
    // before sign-in. Writes are not allowed from the client; manage trucks
    // from the Firebase console or a trusted backend (Admin SDK).
    match /foodTrucks/{truckId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
